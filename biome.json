{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"linter": {
		"enabled": false
	},
	"files": {
		"includes": ["src/**/*.ts", "*.config.ts", "sample-svelte/src/**/*.ts", "sample-sveltekit/src/**/*.ts"]
	}
}
