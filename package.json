{
	"name": "@svelte-ssv/core",
	"version": "0.2.0",
	"type": "module",
	"description": "Svelte Simple Validation — A lightweight Zod-based form validation library",
	"license": "MIT",
	"author": "ShunichirouKamino",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ShunichirouKamino/svelte-ssv.git"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"form",
		"validation",
		"zod"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./enhance": {
			"import": {
				"types": "./dist/enhance.d.ts",
				"default": "./dist/enhance.js"
			},
			"require": {
				"types": "./dist/enhance.d.cts",
				"default": "./dist/enhance.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"prepublishOnly": "npm run build && npm test"
	},
	"peerDependencies": {
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"jsdom": "^29.0.1",
		"tsup": "^8.5.1",
		"typescript": "~5.8.0",
		"vitest": "^4.1.1",
		"zod": "^4.3.6"
	}
}
